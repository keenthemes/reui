{"$schema":"https://ui.shadcn.com/schema/registry-item.json","name":"c-card-15","type":"registry:block","title":"Stat card with trend and overflow menu","description":"Stat card with trend and overflow menu","dependencies":[],"registryDependencies":["@reui/badge","button","card","dropdown-menu","separator"],"files":[{"path":"c-card-15.tsx","type":"registry:block","content":"import { Badge } from \"@/components/reui/badge\"\n\nimport { Button } from \"@/components/ui/button\"\nimport { Card, CardContent } from \"@/components/ui/card\"\nimport {\n  DropdownMenu,\n  DropdownMenuContent,\n  DropdownMenuGroup,\n  DropdownMenuItem,\n  DropdownMenuSeparator,\n  DropdownMenuTrigger,\n} from \"@/components/ui/dropdown-menu\"\nimport { Separator } from \"@/components/ui/separator\"\nimport { IconPlaceholder } from \"@/app/(create)/customizer/icon-placeholder\"\n\nexport function Pattern() {\n  const title = \"Revenue\"\n  const value = \"$12.4k\"\n  const delta = 12.5\n  const positive = true\n  const lastMonth = \"$11.0k\"\n\n  return (\n    <Card className=\"w-full max-w-xs\">\n      <CardContent className=\"flex flex-col gap-5\">\n        <div className=\"flex items-center justify-between gap-3\">\n          <h3 className=\"text-muted-foreground text-sm font-medium\">{title}</h3>\n          <DropdownMenu>\n            <DropdownMenuTrigger asChild>\n              <Button\n                variant=\"ghost\"\n                size=\"icon\"\n                className=\"-me-1.5\"\n                aria-label=\"More options\"\n              >\n                <IconPlaceholder\n                  lucide=\"MoreHorizontalIcon\"\n                  tabler=\"IconDots\"\n                  hugeicons=\"MoreHorizontalCircle01Icon\"\n                  phosphor=\"DotsThreeIcon\"\n                  remixicon=\"RiMoreLine\"\n                  aria-hidden=\"true\"\n                />\n              </Button>\n            </DropdownMenuTrigger>\n            <DropdownMenuContent align=\"end\" className=\"w-48\">\n              <DropdownMenuGroup>\n                <DropdownMenuItem>\n                  <IconPlaceholder\n                    lucide=\"SettingsIcon\"\n                    tabler=\"IconSettings\"\n                    hugeicons=\"Settings01Icon\"\n                    phosphor=\"GearIcon\"\n                    remixicon=\"RiSettings3Line\"\n                    aria-hidden=\"true\"\n                  />\n                  Settings\n                </DropdownMenuItem>\n                <DropdownMenuItem>\n                  <IconPlaceholder\n                    lucide=\"TriangleAlertIcon\"\n                    tabler=\"IconAlertTriangle\"\n                    hugeicons=\"Alert02Icon\"\n                    phosphor=\"WarningIcon\"\n                    remixicon=\"RiErrorWarningLine\"\n                    aria-hidden=\"true\"\n                  />\n                  Add Alert\n                </DropdownMenuItem>\n                <DropdownMenuItem>\n                  <IconPlaceholder\n                    lucide=\"PinIcon\"\n                    tabler=\"IconPin\"\n                    hugeicons=\"Pin02Icon\"\n                    phosphor=\"PushPinIcon\"\n                    remixicon=\"RiPushpinLine\"\n                    aria-hidden=\"true\"\n                  />\n                  Pin to Dashboard\n                </DropdownMenuItem>\n                <DropdownMenuItem>\n                  <IconPlaceholder\n                    lucide=\"Share2Icon\"\n                    tabler=\"IconShare\"\n                    hugeicons=\"Share08Icon\"\n                    phosphor=\"ShareNetworkIcon\"\n                    remixicon=\"RiStackshareLine\"\n                    aria-hidden=\"true\"\n                  />\n                  Share\n                </DropdownMenuItem>\n                <DropdownMenuSeparator />\n                <DropdownMenuItem variant=\"destructive\">\n                  <IconPlaceholder\n                    lucide=\"TrashIcon\"\n                    tabler=\"IconTrash\"\n                    hugeicons=\"DeleteIcon\"\n                    phosphor=\"TrashIcon\"\n                    remixicon=\"RiDeleteBinLine\"\n                    aria-hidden=\"true\"\n                  />\n                  Remove\n                </DropdownMenuItem>\n              </DropdownMenuGroup>\n            </DropdownMenuContent>\n          </DropdownMenu>\n        </div>\n        <div className=\"space-y-2.5\">\n          <div className=\"flex items-center gap-2.5\">\n            <span className=\"text-foreground text-2xl font-medium tracking-tight tabular-nums\">\n              {value}\n            </span>\n            <Badge variant={positive ? \"success-light\" : \"destructive-light\"}>\n              {positive ? (\n                <IconPlaceholder\n                  lucide=\"ArrowUpIcon\"\n                  tabler=\"IconArrowUp\"\n                  hugeicons=\"ArrowUp02Icon\"\n                  phosphor=\"ArrowUpIcon\"\n                  remixicon=\"RiArrowUpLine\"\n                  aria-hidden=\"true\"\n                />\n              ) : (\n                <IconPlaceholder\n                  lucide=\"ArrowDownIcon\"\n                  tabler=\"IconArrowDown\"\n                  hugeicons=\"ArrowDown02Icon\"\n                  phosphor=\"ArrowDownIcon\"\n                  remixicon=\"RiArrowDownLine\"\n                  aria-hidden=\"true\"\n                />\n              )}\n              {delta}%\n            </Badge>\n          </div>\n          <Separator />\n          <div className=\"text-muted-foreground text-xs\">\n            Vs last month:{\" \"}\n            <span className=\"text-foreground font-medium tabular-nums\">\n              {lastMonth}\n            </span>\n          </div>\n        </div>\n      </CardContent>\n    </Card>\n  )\n}","target":"components/examples/c-card-15.tsx"}]}