{
  "name": "reui",
  "version": "2.1.5",
  "private": true,
  "type": "module",
  "scripts": {
    "predev": "pnpm components:build",
    "dev": "next dev",
    "dev:packages": "pnpm components:build && pnpm components:packages && concurrently -k -n packages,next \"pnpm components:packages:watch\" \"next dev\"",
    "prebuild": "pnpm registry:prod",
    "build": "next build",
    "build:local": "pnpm registry:all && next build",
    "start": "next start",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit",
    "format:write": "prettier --write \"**/*.{ts,tsx,mdx}\" --cache",
    "format:check": "prettier --check \"**/*.{ts,tsx,mdx}\" --cache",
    "components:build": "tsx --tsconfig ./tsconfig.scripts.json ./scripts/build-components.mts",
    "components:packages": "tsx --tsconfig ./tsconfig.scripts.json ./scripts/build-component-packages.mts --wire-app",
    "components:packages:watch": "tsx --tsconfig ./tsconfig.scripts.json ./scripts/build-component-packages.mts --wire-app --watch",
    "registry:watch": "pnpm components:packages:watch",
    "registry:build": "tsx --tsconfig ./tsconfig.scripts.json ./scripts/build-registry.mts",
    "registry:verify": "tsx --tsconfig ./tsconfig.scripts.json ./scripts/verify-registry.mts",
    "registry:prod": "pnpm components:build && pnpm components:packages && pnpm registry:build",
    "registry:all": "pnpm components:build && pnpm components:packages && pnpm registry:build && pnpm registry:verify",
    "postinstall": "fumadocs-mdx && pnpm components:build"
  },
