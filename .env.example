# ReUI runs locally with zero configuration - every value below is optional.
# Copy this file to `.env.local` only if you need to override a default.

# Public site URL. Used for absolute URLs in metadata, sitemap, and OG images.
# Defaults to http://localhost:3000 in development.
# NEXT_PUBLIC_APP_URL=http://localhost:3000
# NEXT_PUBLIC_WEB_URL=http://localhost:3000

# Path to a local checkout of the private ReUI source monorepo, used by
# `pnpm sync` to refresh the component registry. Defaults to `../reui.io`.
# REUI_SOURCE=../reui.io
